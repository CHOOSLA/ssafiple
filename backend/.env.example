DATABASE_URL=sqlite:///./localhub.db
OPENAI_API_KEY=your-openai-api-key-here
# 챗봇에 사용할 OpenAI 모델 (미지정 시 gpt-5-mini)
OPENAI_MODEL=gpt-4o-mini
# Kakao Maps REST API 혹은 프론트엔드 cors 허용을 위한 설정 (Netlify 도메인 등)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# 카카오모빌리티 길찾기 API용 REST API 키 (카카오디벨로퍼스 앱 > 플랫폼 키 > REST API 키)
KAKAO_REST_API_KEY=your-kakao-rest-api-key-here
# 대중교통 길찾기(ODsay) API 키. https://lab.odsay.com 에서 발급 (무료 티어는 일 호출 횟수 제한 있음)
# 키에 이미 percent-encoding된 특수문자가 포함될 수 있으니, .env에 저장할 때 재인코딩하지 말고 발급받은 값 그대로 붙여넣을 것
ODSAY_API_KEY=your-odsay-api-key-here
